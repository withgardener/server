+                         sizeof(ngx_http_error_server_info_head) - 1);
+    b->last = ngx_cpymem(b->last, ngx_cached_http_time.data,
+                         ngx_cached_http_time.len);
+
+    b->last = ngx_cpymem(b->last, ngx_http_error_server_info_ip,
